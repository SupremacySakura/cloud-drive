# ==========================================
# Cloud Drive Backend - 环境变量配置文件
# ==========================================
# 复制此文件为 .env 并修改为你自己的配置
# 警告：生产环境必须修改所有默认值！
# ==========================================

# ==========================================
# 服务器配置
# ==========================================
PORT=9000

# ==========================================
# 数据库配置 (MySQL)
# ==========================================
DB_USER=root
DB_PASSWORD=123456123456
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=cloud-drive

# ==========================================
# JWT 认证配置
# ==========================================
# ⚠️ 重要：生产环境必须使用强密钥！
# 建议使用：openssl rand -base64 32
JWT_SECRET=your_secret_key

# ==========================================
# CORS 配置
# ==========================================
# 允许的前端应用来源，逗号分隔，例如 http://localhost:3000,https://myapp.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ==========================================
# 文件存储路径
# ==========================================
# 分片上传临时存储路径
CHUNK_STORAGE_PATH=./data
# 合并后文件存储路径
FILE_STORAGE_PATH=./data
