COMPOSE_PROJECT_NAME=cloud-drive

# profiles: infra / backend / frontend / full
COMPOSE_PROFILES=full

# image tags
MYSQL_IMAGE=mysql:8.4

# container names
MYSQL_CONTAINER_NAME=cloud-drive-mysql
BACKEND_CONTAINER_NAME=cloud-drive-backend
FRONTEND_CONTAINER_NAME=cloud-drive-frontend

# host ports
MYSQL_PORT=3306
BACKEND_HOST_PORT=9000
FRONTEND_PORT=5173

# backend container runtime port (keep this aligned with frontend's internal upstream: backend:9000)
BACKEND_CONTAINER_PORT=9000
BACKEND_UPSTREAM_HOST=backend

# local bind paths
MYSQL_DATA_DIR=./data/mysql
MYSQL_INIT_DIR=./ops/mysql/init
MYSQL_IMPORT_DIR=./ops/mysql/import

# mysql init
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=cloud-drive
MYSQL_INITDB_SKIP_TZINFO=1

# backend runtime
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=cloud-drive
JWT_SECRET=your_jwt_secret_key
CHUNK_STORAGE_PATH=/app/data
FILE_STORAGE_PATH=/app/data

# compose resource names
NETWORK_NAME=cloud-drive-network
MYSQL_VOLUME_NAME=mysql-data
BACKEND_VOLUME_NAME=backend-data
