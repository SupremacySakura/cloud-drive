{
  "name": "cloud-drive",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "pnpm --filter cloud-drive-frontend vue-tsc -b --pretty false",
    "lint": "eslint \"apps/**/*.{ts,tsx,js,jsx}\"",
    "clean": "tsc -b --clean",
    "prepare": "husky",
    "test": "pnpm --filter cloud-drive-frontend test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.8.2"
  }
}
